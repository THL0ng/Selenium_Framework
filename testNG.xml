<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Template Framework Suite" verbose="1" parallel="classes" thread-count="2">

    <!-- ============================================================
         SMOKE — Chạy nhanh, verify core feature còn sống
         mvn test -Dgroups=smoke
         ============================================================ -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.project.testcases.testCase_01"/>
        </classes>
    </test>

    <!-- ============================================================
         REGRESSION — Chạy toàn bộ
         mvn test
         ============================================================ -->
    <test name="Regression Tests">
        <classes>
            <class name="com.project.testcases.testCase_01"/>
        </classes>
    </test>

</suite>